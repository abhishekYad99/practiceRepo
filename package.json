{
  "name": "task-document-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo: Next.js frontend + Node/Express/Prisma backend for the Task & Document Workspace.",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build:frontend": "npm run build --workspace frontend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:push": "npm run prisma:push --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "db:seed": "npm run db:seed --workspace backend"
  }
}
