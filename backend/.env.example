# Copy to backend/.env and fill in your values.

# PostgreSQL connection string (the DB link). Example:
#   postgresql://user:password@host:5432/dbname?schema=public
DATABASE_URL=

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Server port.
PORT=4000

# Allowed frontend origin(s) for CORS (comma-separated).
CORS_ORIGIN=http://localhost:3000
