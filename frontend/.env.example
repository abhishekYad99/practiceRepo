# Copy this file to .env.local and set the backend API base URL.
#
# The backend runs on port 4000 and serves all routes under /api.
#
# - If you run the backend on YOUR OWN machine:
#     NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
#
# - If you connect to a backend running on a teammate's machine on the same
#   network, use that machine's LAN IP, e.g.:
#     NEXT_PUBLIC_API_BASE_URL=http://192.168.0.131:4000/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
